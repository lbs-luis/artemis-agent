{
	"name": "artemis-agent",
	"private": true,
	"type": "module",

	"workspaces": [
		"apps/*",
		"src/packages/*",
		"web"
	],
	"scripts": {
		"cli": "bun apps/cli/src/index.ts",
		"tui": "bun apps/cli/src/index.tsx",
		"dev": "bun --hot src/http/server.ts",
		"start": "NODE_ENV=production bun src/http/server.ts",
		"lint": "biome check .",
		"fix": "biome check --write .",
		"typecheck": "bunx tsc --noEmit"
	},
	"dependencies": {
		"@artemis/llm-core": "workspace:*",
		"@artemis/session-store": "workspace:*"
	},
	"devDependencies": {
		"@biomejs/biome": "^2.4.16",
		"@types/bun": "latest",
		"bun-plugin-tailwind": "^0.1.2"
	},
	"peerDependencies": {
		"typescript": "^5"
	}
}
